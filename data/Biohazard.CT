                  <AssemblerScript>{$lua}
if syntaxcheck then return end

local memrec = AddressList.getMemoryRecordByID(120)

local timer = createTimer()
timer.Interval = 450 -- 1000 milliseconds = 1 second
timer.OnTimer = function(timer)
  memrec.Active = false -- deactivate the script
  timer.destroy() -- destroy the timer so it doesn't keep running
end
{$asm}

[ENABLE]
globalalloc(update,2048)
CREATETHREAD(update)
update:
call $process+14140
ret
[DISABLE]
