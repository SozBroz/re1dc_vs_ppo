<?xml version="1.0" encoding="utf-8"?>
<CheatTable CheatEngineTableVersion="45">
  <CheatEntries>
    <CheatEntry>
      <ID>1</ID>
      <Description>"Enable"</Description>
      <Options moHideChildren="1" moDeactivateChildrenAsWell="1"/>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript Async="1">[ENABLE]

aobscanmodule(Ammo_AOB,$process,8A 41 FF 75 01) // should be unique
aobscanmodule(Health_AOB,$process,66 39 1D 3C 52 C3 00 7D 06) // should be unique
aobscanmodule(Enemy_Health_AOB,$process,66 29 95 88 00 00 00) // should be unique
aobscanmodule(Timer_AOB,$process,FF 05 10 8E AA 00) // should be unique

alloc(ammo_mem,2048)
alloc(newmem_health,2048)
alloc(newmem_enemy,2048)
alloc(newmem_timer,2048)

label(inf_ammo)
label(inf_health)
label(onehitkill)
label(timer_0)

ammo_mem:
cmp byte ptr [inf_ammo],01
jne code_ammo
jmp code_check_special

code_check_special:
cmp byte ptr [ecx-02],6F
je code_ammo
cmp byte ptr [ecx-02],70
je code_ammo
jmp code_inf_ammo

code_inf_ammo:
mov byte ptr [ecx-01],64
jmp code_ammo

code_ammo:
  mov al,[ecx-01]
  jne $process+AD68
  jmp return_ammo

Ammo_AOB:
  jmp ammo_mem
return_ammo:
registersymbol(Ammo_AOB)
registersymbol(inf_ammo)

ammo_mem+100:
inf_ammo:
db 00

/////////////////////////////////////////

newmem_health:
cmp byte ptr [inf_health],01
jne code_health
  mov al, byte ptr [$process+835329]
  mov byte ptr [$process+83523C],al
  mov byte ptr [$process+835290],10
  cmp [$process+83523C],bx
  jmp return_health

code_health:
  cmp [$process+83523C],bx
  jmp return_health

Health_AOB:
  jmp newmem_health
  nop 2
return_health:
registersymbol(Health_AOB)
registersymbol(inf_health)

newmem_health+100:
inf_health:
db 00

/////////////////////////////////////////

newmem_enemy:
cmp byte ptr [onehitkill],01
jne code_enemy
  mov dx,#999
  jmp code_enemy

code_enemy:
  sub [ebp+00000088],dx
  jmp return_enemy

Enemy_Health_AOB:
  jmp newmem_enemy
  nop 2
return_enemy:
registersymbol(Enemy_Health_AOB)
registersymbol(onehitkill)

newmem_enemy+100:
onehitkill:
db 00

////////////////////////////////////////

newmem_timer:
cmp byte ptr [timer_0],01
jne code_timer
  mov [$process+6A8E10],00
  jmp return_timer

code_timer:
  inc [$process+6A8E10]
  jmp return_timer

Timer_AOB:
  jmp newmem_timer
  nop
return_timer:
registersymbol(Timer_AOB)
registersymbol(timer_0)

newmem_timer+100:
timer_0:
  db 00

[DISABLE]

Ammo_AOB:
  db 8A 41 FF 75 01

unregistersymbol(Ammo_AOB)
dealloc(ammo_mem)
unregistersymbol(inf_ammo)

Health_AOB:
  db 66 39 1D 3C 52 C3 00

unregistersymbol(Health_AOB)
dealloc(newmem_health)
unregistersymbol(inf_health)

Enemy_Health_AOB:
  db 66 29 95 88 00 00 00

unregistersymbol(Enemy_Health_AOB)
dealloc(newmem_enemy)
unregistersymbol(onehitkill)

Timer_AOB:
  db FF 05 10 8E AA 00

unregistersymbol(Timer_AOB)
dealloc(newmem_timer)
unregistersymbol(timer_0)
</AssemblerScript>
